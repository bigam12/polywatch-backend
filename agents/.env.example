# Copy this to .env and fill in your values

# Your Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# URL of your running tracker.js backend
# Local dev: http://localhost:3001
# Render:     https://your-app.onrender.com
BACKEND_URL=http://localhost:3001

# How often to re-run the swarm (seconds) — only used with --loop flag
# 300 = every 5 min, 600 = every 10 min, 1800 = every 30 min
LOOP_INTERVAL=1800

# Minimum confidence score (0-100) to post a signal to the backend
MIN_CONFIDENCE=50

# Hard cap on how many times agents run per day (cost control)
# 48 runs/day at ~$0.001/run = ~$0.05/day = ~$1.50/month max
MAX_RUNS_PER_DAY=48
