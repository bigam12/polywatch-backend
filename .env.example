# PolyWatch Environment Variables
# Copy this file to .env and fill in your values

# ── TELEGRAM ──────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram (/newbot)
TELEGRAM_TOKEN=your_bot_token_here

# Your personal Telegram chat ID
# Get it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# ── TRACKING SETTINGS ─────────────────────────────────────────────────
# How often to poll wallets (milliseconds). 15000 = 15 seconds
POLL_INTERVAL_MS=15000

# Minimum trade size in USD to trigger an alert
MIN_TRADE_SIZE_USD=50

# ── SERVER ────────────────────────────────────────────────────────────
# Port for the local API server (dashboard connects to this)
PORT=3001

# ── DATABASE ──────────────────────────────────────────────────────────
# MongoDB connection string (optional, but recommended for persistence)
# Get a free instance at https://cloud.mongodb.com
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/polywatch
